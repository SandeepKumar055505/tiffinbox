NODE_ENV=development
PORT=3001

# Neon PostgreSQL — copy connection string from Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/tiffinbox?sslmode=require

# Auth
JWT_SECRET=your-256-bit-random-secret-here
JWT_EXPIRES_IN=7d

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Admin seed — creates first admin account on startup (idempotent)
ADMIN_SEED_EMAIL=admin@tiffinbox.in
ADMIN_SEED_PASSWORD=strongpassword123

# Razorpay — from Razorpay dashboard
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Gmail SMTP — use an App Password (not your account password)
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=tiffinbox@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# Cloudinary — for meal item image uploads (optional)
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# Sentry — for error tracking in production (optional)
SENTRY_DSN=
